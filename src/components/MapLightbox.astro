---
import IllustrationLightbox from './IllustrationLightbox.astro';

interface Props {
  slug: string;
  src: string;
  alt: string;
  caption: string;
  width: number;
  height: number;
}

const { slug, src, alt, caption, width, height } = Astro.props;
---

<IllustrationLightbox
  id={slug}
  src={src}
  alt={alt}
  caption={caption}
  variant="map"
  width={width}
  height={height}
/>
