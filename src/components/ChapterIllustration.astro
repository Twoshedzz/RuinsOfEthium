---
interface Props {
  src: string;
  alt: string;
  caption?: string;
  variant?: 'default' | 'cover' | 'wide';
}

const { src, alt, caption, variant = 'default' } = Astro.props;
---

<figure class:list={['illustration-plate', variant !== 'default' && `illustration-plate--${variant}`]}>
  <img src={src} alt={alt} loading="lazy" />
  {caption && <figcaption class="illustration-plate__caption">{caption}</figcaption>}
</figure>
