---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { getPublishedChapters, formatChapterLabel } from '../lib/chapters';
import { SITE_TITLE } from '../lib/site';

const chapters = await getPublishedChapters();
const firstChapter = chapters[0];
---

<BaseLayout title={SITE_TITLE}>
  <SiteHeader slot="header" />

  <div class="container container--cover">
    <section class="cover">
      <div class="cover__hero">
        <figure class="cover__art">
          <img
            src="/illustrations/cover/book-cover-ethium-battle-colour.png"
            alt="Thorn, Derek, Dave, Nibbles and Loki fight goblins among the ruins of Ethium"
            width="1200"
            height="900"
            loading="eager"
          />
        </figure>

        {
          firstChapter ? (
            <div class="cover__overlay cover__overlay--cta">
              <a class="cover__cta" href={`/chapters/${firstChapter.slug}/`}>
                Begin reading
              </a>
            </div>
          ) : (
            <p class="cover__empty">No chapters published yet.</p>
          )
        }
      </div>

      {
        chapters.length > 0 && (
          <section class="recent-chapters">
            <h2>Chapters</h2>
            <ul class="chapter-list">
              {
                chapters.map((chapter) => (
                  <li>
                    <span class="chapter-list__number">
                      {formatChapterLabel(chapter.data.chapter)}
                    </span>
                    <a href={`/chapters/${chapter.slug}/`}>{chapter.data.title}</a>
                    {chapter.data.summary && (
                      <p class="chapter-list__summary">{chapter.data.summary}</p>
                    )}
                  </li>
                ))
              }
            </ul>
          </section>
        )
      }
    </section>
  </div>
</BaseLayout>
